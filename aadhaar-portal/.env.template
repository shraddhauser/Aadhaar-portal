# Aadhaar Portal - Environment Configuration
# Copy this file to .env and update for your local database.

# Database Configuration
DB_ENGINE=sqlite
DB_FILE=./aadhaar_analytics.db
DB_URL=

# MySQL settings (only used when DB_ENGINE=mysql)
DB_USER=root
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=3306
DB_NAME=aadhaar_analytics

# FastAPI Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=True

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-in-production-12345678901234567890
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=24

# Google Gemini API key for AI Chatbot (free tier)
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
